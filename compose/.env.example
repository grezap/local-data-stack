# ──────────────────────────────────────────────────────────────────────────────
#  NexusPlatform · local-data-stack · environment defaults
# ──────────────────────────────────────────────────────────────────────────────
#  Copy this file to `.env` in the same directory. Docker Compose auto-loads it.
#  All values have safe defaults baked into docker-compose.yml; this file only
#  documents the knobs and lets you override without editing the compose file.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Image versions (pinned; managed by Dependabot) ──────────────────────────
KAFKA_VERSION=3.8.1
SCHEMA_REGISTRY_VERSION=7.7.1
CLICKHOUSE_VERSION=24.8.7.41
REDIS_VERSION=7.4-alpine
OTEL_COLLECTOR_VERSION=0.113.0
PROMETHEUS_VERSION=v3.0.1
GRAFANA_VERSION=11.3.0
JAEGER_VERSION=2.0.0
SEQ_VERSION=2024.3

# ─── Kafka ───────────────────────────────────────────────────────────────────
# 22-char base64-url cluster id. Regenerate with: kafka-storage random-uuid
KAFKA_CLUSTER_ID=nexus-local-000000000001

# ─── ClickHouse ──────────────────────────────────────────────────────────────
# Default user/db are hard-coded in compose (nexus/nexus). Override password.
CLICKHOUSE_PASSWORD=nexus-dev

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ─── Seq ─────────────────────────────────────────────────────────────────────
# Generate with:  docker run --rm datalust/seq config hash '<your-password>'
# Leave blank for first-run interactive setup via the UI.
SEQ_ADMIN_PASSWORD_HASH=

# ─── Host ports (override if something on your host already uses them) ───────
# All ports still bind to 127.0.0.1 only; only the host-side number changes.
KAFKA_EXTERNAL_PORT=9094
SCHEMA_REGISTRY_PORT=8081
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_TCP_PORT=9000
REDIS_PORT=6379
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
OTEL_SELF_METRICS_PORT=8888
OTEL_PROM_EXPORTER_PORT=8889
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686
SEQ_PORT=5341
