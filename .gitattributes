# ──────────────────────────────────────────────────────────────────────────────
#  Line-ending & diff policy
# ──────────────────────────────────────────────────────────────────────────────
#  Critical for cross-platform repos: shell scripts MUST stay LF-only because
#  they run inside Linux containers. CRLF in a shell script produces the
#  classic `bash\r: command not found` at exec time.
# ──────────────────────────────────────────────────────────────────────────────

# Default: let Git normalize text files in the repo to LF.
* text=auto eol=lf

# Shell scripts: force LF even when checked out on Windows.
*.sh        text eol=lf
*.bash      text eol=lf

# PowerShell: keep CRLF on Windows checkouts (idiomatic for .ps1).
*.ps1       text eol=crlf
*.psm1      text eol=crlf
*.psd1      text eol=crlf

# Windows batch: always CRLF.
*.bat       text eol=crlf
*.cmd       text eol=crlf

# YAML / JSON / Markdown / SQL: LF everywhere.
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.sql       text eol=lf

# Makefile: tabs required; LF.
Makefile    text eol=lf

# Treat these as binary to avoid corruption.
*.png       binary
*.jpg       binary
*.ico       binary
*.pdf       binary
*.docx      binary
*.xlsx      binary
*.zip       binary

# Language detection / GitHub Linguist hints
*.md         linguist-documentation
docs/**      linguist-documentation
